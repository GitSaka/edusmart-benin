generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 🏫 LE TOIT : L'ÉCOLE (SAAS)
// ==========================================
model Ecole {
  id            Int     @id @default(autoincrement())
  nom           String  @unique
  slug          String  @unique
  code          String  @unique
  adresse       String?
  contact       String?
  logo          String?
  anneeActiveId Int? // 🛡️ LE VERROU TEMPOREL

  // 📍 GÉO-BARRIÉRAGE (GPS)
  latitude  Float? // Latitude de l'école
  longitude Float? // Longitude de l'école
  perimetre Int?   @default(100) // Rayon autorisé pour l'appel (en mètres)

  // Relations inverses obligatoires pour Prisma
  users        User[]
  teachers     Teacher[]
  students     Student[]
  classes      Classe[]
  levels       Level[]
  series       Serie[]
  parents      Parent[]
  matieres     Matiere[]
  cours        Cours[]
  lecons       Lecon[]
  ressources   Ressource[]
  notes        Note[]
  presences    Presence[]
  bulletins    Bulletin[]
  paiements    Paiement[]
  annonces     Annonce[]
  feedbacks    Feedback[]
  logs         ActivityLog[]
  historiques  HistoriqueScolaire[]
  audits       NoteAudit[]
  timetables   Timetable[]
  annee        AnneeScolaire[]
  coefficients Coefficient[]
  library      Library[]

  createdAt DateTime @default(now())
  Device    Device[]
}

model AnneeScolaire {
  id        Int     @id @default(autoincrement())
  libelle   String // ex: "2024-2025" ou "2025-2026"
  estActive Boolean @default(false) // Une seule année est active à la fois par école

  // 🛡️ LIAISON ÉCOLE (Chaque école a son propre calendrier)
  ecoleId Int
  ecole   Ecole         @relation(fields: [ecoleId], references: [id])
  logs    ActivityLog[]

  verrous     VerrouSaisie[]
  // 🔗 RELATIONS POUR L'ARCHIVAGE
  classes     Classe[] // Les classes créées spécifiquement pour cette année
  historiques HistoriqueScolaire[] // Les traces des élèves pour cette année

  students     Student[]
  presences    Presence[]
  notes        Note[]
  cours        Cours[]
  timetables   Timetable[]
  ressources   Ressource[]
  bulletins    Bulletin[]
  lecons       Lecon[]
  coefficients Coefficient[]
  paiements    Paiement[]

  createdAt DateTime @default(now())
}

// ==========================================
// 👤 UTILISATEURS ET PROFILS
// ==========================================
model User {
  id       String        @id @default(uuid())
  username String        @unique
  password String
  role     UserRole
  logs     ActivityLog[]

  ecoleId Int?
  ecole   Ecole? @relation(fields: [ecoleId], references: [id])

  parent  Parent?
  student Student?
  teacher Teacher?
}

model Teacher {
  id        String  @id @default(uuid())
  nom       String
  prenom    String
  telephone String  @unique
  img       String?
  matiereId Int
  userId    String  @unique

  ecoleId Int?
  ecole   Ecole? @relation(fields: [ecoleId], references: [id])

  classeDirigee Classe?     @relation("ProfPrincipal")
  cours         Cours[]
  notes         Note[]
  ressources    Ressource[]
  matiere       Matiere     @relation(fields: [matiereId], references: [id])
  user          User        @relation(fields: [userId], references: [id])
  classes       Classe[]    @relation("TeacherClasses")
}

model Student {
  id            String   @id @default(uuid())
  matricule     String
  nom           String
  prenom        String
  sexe          String
  pointsHonneur Int      @default(0)
  parentId      String
  dateNaissance DateTime
  abonne        Boolean  @default(true)
  adresse       String
  classeId      Int
  img           String?
  tabletteId    String?
  userId        String   @unique

  lieuNaissance String  @default("Cotonou")
  nationalite   String  @default("Béninoise")
  redoublant    Boolean @default(false)

  lat  String?
  long String?

  ecoleId Int?
  ecole   Ecole? @relation(fields: [ecoleId], references: [id])

  // 📅 LE VERROU TEMPOREL (À AJOUTER)
  anneeId Int?
  annee   AnneeScolaire? @relation(fields: [anneeId], references: [id])

  logsActivite  ActivityLog[]
  bulletins     Bulletin[]
  notifications Notification[]

  historiques HistoriqueScolaire[]
  notes       Note[]
  paiements   Paiement[]
  presences   Presence[]
  classe      Classe               @relation(fields: [classeId], references: [id])
  parent      Parent               @relation(fields: [parentId], references: [id])
  user        User                 @relation(fields: [userId], references: [id])
  Device      Device?

  scolariteTotale   Float       @default(0) // ✅ Pour le calcul financier
  autoBloquage      Boolean     @default(true) // ✅ Décision de bloquer ou non si dette
  ressourcesPrivees Ressource[] @relation("PrivateRessources")

  @@unique([matricule, ecoleId])
  @@unique([tabletteId, ecoleId])
}

model Notification {
  id      Int      @id @default(autoincrement())
  message String // Le texte du SMS (ex: "Relance Scolarité...")
  type    String // "FINANCE", "PRESENCE", "ALERTE"
  statut  String   @default("SENT") // "SENT", "FAILED"
  sentAt  DateTime @default(now())

  studentId String
  student   Student @relation(fields: [studentId], references: [id])
}

model Parent {
  id        String @id @default(uuid())
  nom       String
  prenom    String
  telephone String @unique
  userId    String @unique

  ecoleId Int?
  ecole   Ecole? @relation(fields: [ecoleId], references: [id])

  user    User      @relation(fields: [userId], references: [id])
  enfants Student[]
}

// ==========================================
// 🏗️ STRUCTURE SCOLAIRE
// ==========================================
model Level {
  id            Int    @id @default(autoincrement())
  nom           String @unique
  scolariteBase Float  @default(0)

  ecoleId Int?
  ecole   Ecole? @relation(fields: [ecoleId], references: [id])

  classes    Classe[]
  ressources Ressource[]
  series     Serie[]
  library    Library[]
}

model Serie {
  id      Int    @id @default(autoincrement())
  nom     String
  levelId Int

  ecoleId Int?
  ecole   Ecole? @relation(fields: [ecoleId], references: [id])

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  classes      Classe[]
  coefficients Coefficient[]
  library      Library[]
  level        Level         @relation(fields: [levelId], references: [id])

  @@unique([nom, levelId])
}

model Classe {
  id              Int     @id @default(autoincrement())
  nom             String  @unique
  capacite        Int
  scolariteBase   Float   @default(0)
  profPrincipalId String? @unique
  levelId         Int
  serieId         Int?

  ecoleId Int?
  ecole   Ecole? @relation(fields: [ecoleId], references: [id])

  anneeId Int
  annee   AnneeScolaire @relation(fields: [anneeId], references: [id])

  annonces  Annonce[]
  bulletins Bulletin[]

  verrousSaisie VerrouSaisie[]

  level         Level                @relation(fields: [levelId], references: [id])
  profPrincipal Teacher?             @relation("ProfPrincipal", fields: [profPrincipalId], references: [id])
  serie         Serie?               @relation(fields: [serieId], references: [id])
  cours         Cours[]
  Feedback      Feedback[]
  historiques   HistoriqueScolaire[]
  ressources    Ressource[]
  eleves        Student[]
  teachers      Teacher[]            @relation("TeacherClasses")
}

model Matiere {
  id                Int    @id @default(autoincrement())
  nom               String @unique
  coefficientDefaut Int    @default(2)

  ecoleId Int?
  ecole   Ecole? @relation(fields: [ecoleId], references: [id])

  coefficients Coefficient[]
  cours        Cours[]
  notes        Note[]
  lecons       Lecon[]
  teachers     Teacher[]
}

model Coefficient {
  id        Int @id @default(autoincrement())
  valeur    Int
  matiereId Int
  serieId   Int

  // ✅ AJOUTS LOGIQUES POUR LE SAAS
  ecoleId Int?
  ecole   Ecole? @relation(fields: [ecoleId], references: [id])

  anneeId Int?
  annee   AnneeScolaire? @relation(fields: [anneeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  matiere   Matiere  @relation(fields: [matiereId], references: [id])
  serie     Serie    @relation(fields: [serieId], references: [id])

  @@unique([matiereId, serieId, ecoleId, anneeId])
}

// ==========================================
// 📖 PÉDAGOGIE ET NOTES
// ==========================================
model Cours {
  id            Int     @id @default(autoincrement())
  saisieOuverte Boolean @default(true)

  ecoleId Int?
  ecole   Ecole? @relation(fields: [ecoleId], references: [id])

  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id])

  matiereId Int
  matiere   Matiere @relation(fields: [matiereId], references: [id])

  lecons     Lecon[]
  ressources Ressource[]

  classeId Int
  classe   Classe @relation(fields: [classeId], references: [id])

  anneeId Int? // 📅 LE CHAMP MANQUANT
  annee   AnneeScolaire? @relation(fields: [anneeId], references: [id])

  notes     Note[]
  presences Presence[]
  timetable Timetable[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teacherId, matiereId, classeId])
}

model VerrouSaisie {
  id        Int      @id @default(autoincrement())
  classeId  Int
  trimestre Int // 1, 2 ou 3
  anneeId   Int
  estBloque Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relation vers la classe
  classe Classe @relation(fields: [classeId], references: [id], onDelete: Cascade)

  annee AnneeScolaire @relation(fields: [anneeId], references: [id])

  // 🔒 LA CLÉ UNIQUE (Très important pour ton Action Upsert)
  @@unique([classeId, trimestre, anneeId])
  @@index([classeId])
  @@index([anneeId])
}

model EpreuveArchive {
  id    Int    @id @default(autoincrement())
  titre String // ex: "Mathématiques - Série D"

  // 🎯 LES SÉLECTEURS (Tes futurs <select>)
  type      String // "DEVOIR", "EXAMEN_BLANC", "EXAMEN_NATIONAL"
  examen    String? // "BAC", "BEPC", "CEPE", "CAP" (Optionnel si simple Devoir)
  trimestre Int? // 1, 2 ou 3 (Surtout pour les Devoirs)
  session   Int // L'année réelle de l'épreuve (ex: 2018, 2023)
  auteur    String?
  auteurId  String

  matiere String // On écrit le nom en texte pour l'indépendance
  classe  String // ex: "Terminale", "3ème", "Seconde"
  serie   String? // "D", "C", "A1", "G2"

  // 📄 LES FICHIERS
  fichierUrl      String // Le sujet (PDF)
  fichierPublicId String
  corrigeUrl      String? // Le corrigé (PDF)
  corrigePublicId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([examen])
  @@index([session])
}

model Lecon {
  id          Int     @id @default(autoincrement())
  titre       String
  description String?
  ordre       Int     @default(1)

  anneeId Int?
  annee   AnneeScolaire? @relation(fields: [anneeId], references: [id])

  ecoleId Int?
  ecole   Ecole? @relation(fields: [ecoleId], references: [id])

  matiereId  Int
  classeId   Int?
  levelId    Int?
  matiere    Matiere     @relation(fields: [matiereId], references: [id])
  ressources Ressource[]
  cours      Cours[]
  createdAt  DateTime    @default(now())
}

model Ressource {
  id          Int           @id @default(autoincrement())
  titre       String
  url         String
  type        RessourceType
  portee      Portee        @default(CLASSE)
  isPublished Boolean       @default(true)
  publicId    String?
  size        Int?
  isRead    Boolean  @default(false)

  ecoleId Int?
  ecole   Ecole? @relation(fields: [ecoleId], references: [id])

  studentId String?
  student   Student? @relation("PrivateRessources", fields: [studentId], references: [id])

  anneeId Int?
  annee   AnneeScolaire? @relation(fields: [anneeId], references: [id])
  

  coursId       Int?
  cours         Cours?   @relation(fields: [coursId], references: [id])
  transcription Json?
  indexVector   Json?
  teacherId     String
  classeId      Int?
  levelId       Int
  leconId       Int
  classe        Classe?  @relation(fields: [classeId], references: [id])
  lecon         Lecon    @relation(fields: [leconId], references: [id])
  level         Level    @relation(fields: [levelId], references: [id])
  teacher       Teacher  @relation(fields: [teacherId], references: [id])
  createdAt     DateTime @default(now())
}

// ==========================================
// 📚 LA BIBLIOTHÈQUE NUMÉRIQUE (ANNALES & FASCICULES)
// ==========================================
model Library {
  id            Int     @id @default(autoincrement())
  titre         String // ex: "Passion Mathématiques"
  auteur        String? // ex: "Prof. Dossou"
  couverture    String? // URL de l'image (Cloudinary ou /public)
  coverPublicId String? // 🔑 Pour supprimer l'image sur Cloudinary
  fichierUrl    String // URL du PDF sécurisé
  filePublicId  String? // 🔑 Pour supprimer le PDF sur Cloudinary

  // 🎯 TYPOLOGIE
  type        DocType @default(ANNALE)
  description String? @db.Text

  // 🎯 CIBLAGE (Le livre apparaît selon le niveau de l'élève)
  levelId Int
  level   Level @relation(fields: [levelId], references: [id])

  serieId Int? // Optionnel (ex: Uniquement pour Série C)
  serie   Serie? @relation(fields: [serieId], references: [id])

  // 🛡️ SÉCURITÉ & ACCÈS
  isProtected Boolean @default(true) // Si true, passe par le Proxy API
  isPublished Boolean @default(true)
  viewCount   Int     @default(0) // Pour voir les livres les plus lus

  // 🏫 MULTI-TENANT (Optionnel : si le livre est propre à une école)
  ecoleId Int?
  ecole   Ecole? @relation(fields: [ecoleId], references: [id])

  matiere LibMatiere

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([levelId])
  @@index([type])
}

model Note {
  id         Int      @id @default(autoincrement())
  valeur     Float
  type       TypeNote
  trimestre  Int      @default(1)
  estValidee Boolean  @default(false)

  ecoleId Int?
  ecole   Ecole? @relation(fields: [ecoleId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studentId String
  coursId   Int
  cours     Cours       @relation(fields: [coursId], references: [id])
  student   Student     @relation(fields: [studentId], references: [id])
  audits    NoteAudit[]

  teacherId String?
  teacher   Teacher?       @relation(fields: [teacherId], references: [id])
  matiereId Int?
  matiere   Matiere?       @relation(fields: [matiereId], references: [id])
  anneeId   Int?
  annee     AnneeScolaire? @relation(fields: [anneeId], references: [id])

  @@unique([studentId, coursId, type, trimestre])
}

model NoteAudit {
  id             Int      @id @default(autoincrement())
  ancienneValeur Float
  nouvelleValeur Float
  date           DateTime @default(now())

  ecoleId Int?
  ecole   Ecole? @relation(fields: [ecoleId], references: [id])

  noteId    Int
  teacherId String
  note      Note   @relation(fields: [noteId], references: [id])
}

// ==========================================
// 📅 VIE SCOLAIRE ET ADMINISTRATION
// ==========================================
model Timetable {
  id         Int    @id @default(autoincrement())
  jour       Day
  heureDebut String
  heureFin   String

  ecoleId Int?
  ecole   Ecole? @relation(fields: [ecoleId], references: [id])

  anneeId Int?
  annee   AnneeScolaire? @relation(fields: [anneeId], references: [id])

  coursId Int
  cours   Cours @relation(fields: [coursId], references: [id])
}

model Presence {
  id         Int      @id @default(autoincrement())
  date       DateTime @default(now())
  estPresent Boolean  @default(true)

  lat  String?
  long String?

  ecoleId   Int?
  ecole     Ecole?         @relation(fields: [ecoleId], references: [id])
  anneeId   Int?
  annee     AnneeScolaire? @relation(fields: [anneeId], references: [id])
  studentId String
  coursId   Int
  cours     Cours          @relation(fields: [coursId], references: [id])
  student   Student        @relation(fields: [studentId], references: [id])
}

model Bulletin {
  id        Int   @id @default(autoincrement())
  trimestre Int
  moyenne   Float
  rang      Int
  details   Json?

  ecoleId Int?
  ecole   Ecole? @relation(fields: [ecoleId], references: [id])

  estPublie Boolean @default(false)

  classeId Int?
  classe   Classe? @relation(fields: [classeId], references: [id])

  anneeId Int?
  annee   AnneeScolaire? @relation(fields: [anneeId], references: [id])

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  @@unique([studentId, trimestre, anneeId], name: "id_trimestre_studentId")
}

model Paiement {
  id       Int        @id @default(autoincrement())
  montant  Float
  reste    Float      @default(0)
  date     DateTime   @default(now())
  echeance DateTime?
  tranche  String
  statut   StatutPaye
  methode  String     @default("ESPECES")

  // 🔑 L'ANNÉE SCOLAIRE (Indispensable pour ne pas mélanger les dettes)
  anneeId Int?
  annee   AnneeScolaire? @relation(fields: [anneeId], references: [id])

  // 👤 QUI A ENCAISSÉ ? (Pour éviter les vols à la caisse)
  recuParId String?

  ecoleId   Int?
  ecole     Ecole?  @relation(fields: [ecoleId], references: [id])
  studentId String
  student   Student @relation(fields: [studentId], references: [id])
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  studentId String
  action    String
  date      DateTime @default(now())
  duree     Int
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  ecoleId Int?
  ecole   Ecole? @relation(fields: [ecoleId], references: [id])

  anneeId Int?
  annee   AnneeScolaire? @relation(fields: [anneeId], references: [id])

  ressourceId Int? // Optionnel : pour savoir quel cours a été vu

  student Student @relation(fields: [studentId], references: [id])
}

model Annonce {
  id      Int      @id @default(autoincrement())
  title   String
  content String
  date    DateTime @default(now())

  ecoleId Int?
  ecole   Ecole? @relation(fields: [ecoleId], references: [id])

  classeId Int?
  classe   Classe? @relation(fields: [classeId], references: [id])
}

model Feedback {
  id      Int    @id @default(autoincrement())
  sujet   String
  message String

  ecoleId Int?
  ecole   Ecole? @relation(fields: [ecoleId], references: [id])

  classeId  Int
  createdAt DateTime @default(now())
  classe    Classe   @relation(fields: [classeId], references: [id])
}

model HistoriqueScolaire {
  id      Int    @id @default(autoincrement())
  moyenne Float
  rang    Int
  statut  String @default("INSCRIT")

  ecoleId Int?
  ecole   Ecole? @relation(fields: [ecoleId], references: [id])

  studentId String
  classeId  Int
  classe    Classe  @relation(fields: [classeId], references: [id])
  student   Student @relation(fields: [studentId], references: [id])

  anneeId Int
  annee   AnneeScolaire @relation(fields: [anneeId], references: [id])

  @@unique([studentId, anneeId])
}

model Device {
  id     Int     @id @default(autoincrement())
  imei   String  @unique // Identifiant physique de la tablette
  modele String?
  statut Boolean @default(true) // true = autorisé, false = bloqué

  lat     Float?   // Latitude actuelle de la tablette
  long    Float?   // Longitude actuelle de la tablette
  lastSeen DateTime @default(now()) // Pour savoir si le signal est frais
  nomZone String? @default("Inconnu") // ex: "Maison", "École", "Trajet"

  studentId String?  @unique
  student   Student? @relation(fields: [studentId], references: [id])

  ecoleId Int
  ecole   Ecole @relation(fields: [ecoleId], references: [id])

  // 🛰️ CONTRÔLE À DISTANCE (MDM)
  isKioskMode       Boolean  @default(true) // 🚫 Bloque sur l'appli EduSmart (Pas de TikTok)
  lastPing          DateTime @default(now()) // 📡 Vérifie si la tablette est en ligne
  batterie          Int? // 🔋 Pour savoir si l'élève a chargé sa tablette
  versionApp        String? // 🚀 Force la mise à jour si trop vieille
  perimetreAutorise Int?     @default(500) // ✅ GÉO-FENCING
  appsAutorisees    String[] @default(["EduSmart"]) // ✅ LISTE BLANCHE
  modeExamen        Boolean  @default(false) // ✅ BLOQUAGE SPÉCIAL EXAMEN
  // 💰 BLOCAGE FINANCIER
  motifBlocage      String? // ex: "Scolarité impayée" ou "Vol déclaré"

  derniereIp String?
  updatedAt  DateTime @updatedAt
}

// ==========================================
// ⚙️ ENUMÉRATIONS (Correction Format)
// ==========================================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  TEACHER
  STUDENT
  PARENT
}

enum Day {
  LUNDI
  MARDI
  MERCREDI
  JEUDI
  VENDREDI
  SAMEDI
}

enum DocType {
  ANNALE // Sujets d'examens (Maths, SVT, PCT...)
  FASCICULE // Guides de révision (Passion Maths, résumés...)
  LIVRE_PROGRAMME // Livres officiels (CIAM, manuels d'Histoire...)
  ROMAN // Œuvres intégrales (Français, Philo...)
  CULTURE_G // Documents de culture générale et actualité
  LANGUES // Méthodes d'Anglais, vocabulaire...
  CORRIGE_TYPE // Solutions détaillées des exercices
}

enum LibMatiere {
  MATHS
  PCT
  SVT
  FRANCAIS
  PHILO
  ANGLAIS
  HG
  GENERAL
}

enum TypeNote {
  INT1
  INT2
  INT3
  INT4
  DEV1
  DEV2
}

enum RessourceType {
  VIDEO
  AUDIO
  PDF
}

enum Portee {
  CLASSE
  NIVEAU
}

enum StatutPaye {
  SOLDE
  AVANCE
  IMPAYE
}
